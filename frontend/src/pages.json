{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "@/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "今日打卡",
        "navigationBarBackgroundColor": "#2C3E50",
        "navigationBarTextStyle": "white",
        "backgroundColor": "#F5F7FA"
      }
    },
    {
      "path": "pages/focus/focus",
      "style": {
        "navigationBarTitleText": "自律钟",
        "navigationBarBackgroundColor": "#2C3E50",
        "navigationBarTextStyle": "white",
        "backgroundColor": "#F5F7FA"
      }
    },
    {
      "path": "pages/room/room",
      "style": {
        "navigationBarTitleText": "搭子自习室",
        "navigationBarBackgroundColor": "#2C3E50",
        "navigationBarTextStyle": "white",
        "backgroundColor": "#F5F7FA"
      }
    },
    {
      "path": "pages/profile/profile",
      "style": {
        "navigationBarTitleText": "个人中心",
        "navigationBarBackgroundColor": "#2C3E50",
        "navigationBarTextStyle": "white",
        "backgroundColor": "#F5F7FA"
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarBackgroundColor": "#2C3E50",
        "navigationBarTextStyle": "white",
        "backgroundColor": "#F5F7FA"
      }
    }
  ],
  "tabBar": {
    "color": "#95A5A6",
    "selectedColor": "#2C3E50",
    "borderStyle": "white",
    "backgroundColor": "#FFFFFF",
    "height": "56px",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "打卡",
        "iconPath": "static/tab-check.svg",
        "selectedIconPath": "static/tab-check-active.svg"
      },
      {
        "pagePath": "pages/focus/focus",
        "text": "自律",
        "iconPath": "static/tab-focus.svg",
        "selectedIconPath": "static/tab-focus-active.svg"
      },
      {
        "pagePath": "pages/room/room",
        "text": "自习室",
        "iconPath": "static/tab-room.svg",
        "selectedIconPath": "static/tab-room-active.svg"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "统计",
        "iconPath": "static/tab-profile.svg",
        "selectedIconPath": "static/tab-profile-active.svg"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "自律搭子",
    "navigationBarBackgroundColor": "#2C3E50",
    "backgroundColor": "#F5F7FA"
  }
}
